# Force LF line endings for all text files
* text=auto

# Explicitly set LF for known text file types
*.py text eol=lf
*.bat text eol=crlf
*.sh text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.exe binary
*.db binary
*.db-shm binary
*.db-wal binary

# Session JSON files - must be LF to avoid diff noise
sync_sessions/*.json text eol=lf